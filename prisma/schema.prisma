// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  STAFF
  VIEWER
}

enum PlatformRole {
  PLATFORM_ADMIN
  BILLING_AGENT
  SUPPORT_AGENT
  PLATFORM_STAFF
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  INVITE
  PASSWORD_RESET
  MFA
}

enum AuthAccountType {
  EMAIL
  PHONE
}

enum SessionEndReason {
  LOGOUT
  EXPIRED
  REVOKED
  REPLACED
}

enum SenderType {
  IDENTITY
  CUSTOMER
  SYSTEM
}

enum PermissionSource {
  MANUAL
  INHERITED
  SYSTEM
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum AuditSource {
  ADMIN_PANEL
  API
  SYSTEM
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_SAY
}

enum NotificationTargetType {
  IDENTITY
  CUSTOMER
  BOTH
  WORKSPACE
  PLATFORM
}

enum SupportContextType {
  PLATFORM
  WORKSPACE
  CUSTOMER
}

enum EntitlementSource {
  PLAN
  MANUAL
  SYSTEM
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCESS
  FAILED
  CANCELLED
}

enum PaymentType {
  SIGNUP
  UPGRADE
  DOWNGRADE
  RENEWAL
  ONE_TIME
  ADDON
}

enum ProductType {
  SUBSCRIPTION
  ONE_TIME
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  EXPIRED
  TRIALING
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum RefundReason {
  USER_REQUEST
  DUPLICATE
  FRAUD
  PAYMENT_ERROR
  UPGRADE_ADJUSTMENT
  DOWNGRADE_ADJUSTMENT
  OTHER
}

enum Currency {
  USD
  EUR
  GBP
  INR
  AUD
  CAD
}

// -------------------- CORE MODELS --------------------

// Workspace (previously Tenant)
model Workspace {
  id             String                @id @default(uuid()) @db.Uuid
  name           String
  slug           String                @unique
  defaultDomain  String?               @map("default_domain")
  primaryEmail   String?               @map("primary_email")
  isActive       Boolean               @default(true) @map("is_active")

  // Multi-domain support
  domains        WorkspaceDomain[]

  // members & roles
  memberships    Membership[]

  // customers (end-users of a workspace product)
  customers      Customer[]

  // auth
  otpRequests    OtpRequest[]
  sessions       Session[]

  // settings & history
  settings       WorkspaceSettings?

  // permissions
  userPermissions UserPermission[]
  workspaceRolePermissions WorkspaceRolePermission[]

  // invites
  invites        WorkspaceInvite[]

  // api keys
  apiKeys        ApiKey[]

  // support
  supportTickets SupportTicket[]
  supportMessages SupportTicketMessage[]

  // notifications
  notifications  Notification[] 

  // features & limits
  featureOverrides WorkspaceFeatureOverride[]
  limitOverrides WorkspaceLimitOverride[]

  // billing
  subscriptions Subscription[]
  payments Payment[]
  invoices Invoice[]

  // audit / webhooks
  adminAuditLogs AdminAuditLog[] 

  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([createdAt])
  @@index([primaryEmail])
}

// workspace domains (CNAMEs / custom domains)
model WorkspaceDomain {
  id         String    @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  workspace  Workspace @relation(fields: [workspaceId], references: [id])

  domain     String   // e.g. workspace.com or acme.platform.com
  isPrimary  Boolean  @default(false) @map("is_primary")
  isVerified Boolean  @default(false) @map("is_verified")

  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([domain])
  @@index([workspaceId, isPrimary])
}

// memberships: join table Identity <-> Workspace (many-to-many)
model Membership {
  id        String        @id @default(uuid()) @db.Uuid
 
  workspaceId String      @map("workspace_id") @db.Uuid
  workspace Workspace     @relation(fields: [workspaceId], references: [id])

  identityId String      @map("identity_id") @db.Uuid
  identity  Identity     @relation(fields: [identityId], references: [id])

  role      WorkspaceRole @default(STAFF)
  isActive  Boolean       @default(true) @map("is_active")

  sessions  Session[]
  // optional temporary access expiry
  expiresAt DateTime?     @map("expires_at")

  version   Int           @default(1)

  createdAt DateTime      @default(now()) @map("created_at")

  @@unique([workspaceId, identityId])
  @@index([identityId])
  @@index([workspaceId, role])
}

// Workspace invites (separate from Membership)
model WorkspaceInvite {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  email       String
  role        WorkspaceRole @default(STAFF)
  invitedById String?  @map("invited_by") @db.Uuid
  invitedBy   Identity? @relation(fields: [invitedById], references: [id])

  token       String   @unique
  status      InviteStatus   @default(PENDING)
  expiresAt   DateTime?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId, status])
  @@index([token, workspaceId])
  @@index([email, workspaceId])
}

model WorkspaceSettings {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  themes      Json // free-form JSON for theme settings (colors, fonts, etc.)
  
  settings    Json // free-form JSON for extensible settings (branding, flags)

  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([workspaceId])
}

model Identity {
  id        String @id @default(uuid()) @db.Uuid
  firstName String? @map("first_name") @db.VarChar(255)
  lastName  String? @map("last_name") @db.VarChar(255)

  email     String? @unique
  phone     String? @unique

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authAccounts AuthAccount[]
  oauthAccounts OAuthAccount[]
  sessions Session[]

  platformInvites PlatformInvite[]
  platformMemberships PlatformMembership[]

  memberships Membership[]
  customers Customer[]
  permissions UserPermission[] @relation("UserPermissions")
  permissionsGranted UserPermission[] @relation("PermissionGrantedBy")
  permissionsRevoked UserPermission[] @relation("PermissionRevokedBy")
  adminAuditLogs AdminAuditLog[]
  invites WorkspaceInvite[]
  apiKeys ApiKey[]
  
  sentTickets SupportTicket[] @relation("CreatedTickets")
  supportMessages SupportTicketMessage[] @relation("SentMessages")
  assignedTickets SupportTicket[] @relation("AssignedTickets")
  notifications Notification[]

  subscriptions Subscription[]
  payments Payment[]
  invoices Invoice[]  
}

model AuthAccount {
  id String @id @default(uuid()) @db.Uuid

  identityId String @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  type  AuthAccountType   // EMAIL | PHONE
  value String   // email address or phone number

  isVerified Boolean @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")

  passwordHash String? @map("password_hash")

  createdAt DateTime @default(now()) @map("created_at")

  optRequests OtpRequest[]

  @@unique([type, value])
  @@index([identityId])
  @@index([identityId, type])
}

// OAuth linked accounts for Identities (Google, etc.)
model OAuthAccount {
  id                 String   @id @default(uuid()) @db.Uuid

  identityId String @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  provider           String   // 'google', 'github', etc.
  providerAccountId  String   @map("provider_account_id")
  accessToken        String? @map("access_token")
  refreshToken       String? @map("refresh_token")
  scope              String? 

  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([provider, providerAccountId])
  @@index([identityId])
}

// Customers (end-users of a workspace product)
model Customer {
  id          String   @id @default(uuid()) @db.Uuid

  identityId String @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  workspaceId String   @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  externalId  String?   @map("external_id") // for external systems

  notifications Notification[]
  subscriptions Subscription[]
  payments Payment[]
  invoices Invoice[]
  supportTickets SupportTicket[] @relation("CreatedCustomerTickets")
  supportMessages SupportTicketMessage[]

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, identityId])
  @@index([workspaceId])
}

// API keys (tenant/workspace scoped)
model ApiKey {
  id         String   @id @default(uuid()) @db.Uuid
  workspaceId String  @map("workspace_id") @db.Uuid
  workspace  Workspace @relation(fields: [workspaceId], references: [id])

  key        String   @unique
  description String?
  scopes     String[] // e.g. ["orders:read","orders:write"]
  createdById String? @map("created_by") @db.Uuid
  createdBy  Identity? @relation(fields: [createdById], references: [id])

  isActive   Boolean  @default(true) @map("is_active")
  expiresAt  DateTime?

  createdAt  DateTime @default(now()) @map("created_at")
  @@index([workspaceId, isActive])
}


// OTP requests (for email/phone OTP)
model OtpRequest {
  id             String    @id @default(uuid()) @db.Uuid
  authAccountId  String    @map("auth_account_id") @db.Uuid
  authAccount    AuthAccount @relation(fields: [authAccountId], references: [id])

  workspaceId    String?   @map("workspace_id") @db.Uuid
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])

  verificationId String   @map("verification_id") @unique @db.Uuid
  otpPurpose     OtpPurpose @map("otp_purpose")
  otpHash        String    @map("otp_hash")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  attempts       Int       @default(0) @db.SmallInt
  resendCount    Int       @default(0) @map("resend_count") @db.SmallInt

  @@index([authAccountId, otpPurpose, createdAt])
  @@index([expiresAt])
}

// Sessions 
model Session {
  id        String   @id @default(uuid()) @db.Uuid

  identityId String  @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  // workspace context - nullable for platform-wide sessions
  workspaceId String? @map("workspace_id") @db.Uuid
  workspace  Workspace? @relation(fields: [workspaceId], references: [id])

  membershipId String? @map("membership_id") @db.Uuid
  membership   Membership? @relation(fields: [membershipId], references: [id])

  workspaceRole WorkspaceRole? @map("workspace_role") 

  ip        String?
  browser   String?
  os        String?
  device    String?
  deviceId  String?   @map("device_id")
  deviceFingerprint String? @map("device_fingerprint")
  userAgent String?   @map("user_agent")

  isActive  Boolean   @default(true) @map("is_active")

  expiresAt DateTime @map("expires_at")
  endedAt   DateTime? @map("ended_at")
  endedReason SessionEndReason? @map("ended_reason")

  lastSeenAt DateTime? @map("last_seen_at")

  createdAt DateTime  @default(now()) @map("created_at")

  @@index([identityId, isActive, createdAt])
  @@index([workspaceId, isActive, createdAt])
  @@index([isActive, expiresAt])
  @@index([deviceId])
  @@index([deviceFingerprint])
  @@index([membershipId])
  @@index([workspaceId])
}

model PlatformInvite {
  id          String   @id @default(uuid()) @db.Uuid

  email       String
  role        PlatformRole

  invitedById String?  @map("invited_by") @db.Uuid
  invitedBy   Identity? @relation(fields: [invitedById], references: [id])

  token       String   @unique
  status      InviteStatus   @default(PENDING)
  expiresAt   DateTime?

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([email, status])
  @@index([token])
}

model PlatformMembership {
  id String @id @default(uuid()) @db.Uuid

  identityId String @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  role PlatformRole

  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([identityId, role])
  @@index([identityId, isActive])
}

// Permission models
model Permission {
  id          String   @id @default(uuid()) @db.Uuid

  key         String @unique
  name        String?
  description String?
  entity      String
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userPermissions UserPermission[]
  rolePermissions RolePermission[]
  workspaceRolePermissions WorkspaceRolePermission[]

  @@index([entity])
  @@index([entity, isActive])
}

model RolePermission {
  id String @id @default(uuid()) @db.Uuid

  workspaceRole WorkspaceRole? @map("workspace_role")
  platformRole PlatformRole? @map("platform_role")

  permissionId String   @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([platformRole, permissionId])
  @@unique([workspaceRole, permissionId])
  @@index([platformRole])
  @@index([workspaceRole])
  @@index([permissionId])
}

model WorkspaceRolePermission {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceRole WorkspaceRole @map("workspace_role")

  permissionId String  @map("permission_id") @db.Uuid
  permission Permission @relation(fields: [permissionId], references: [id])

  isAllowed Boolean @default(true)

  @@unique([workspaceId, workspaceRole, permissionId])
  @@index([workspaceId, workspaceRole])
  @@index([permissionId])
}

model UserPermission {
  id String @id @default(uuid()) @db.Uuid

  identityId String @map("identity_id") @db.Uuid
  identity   Identity @relation("UserPermissions", fields: [identityId], references: [id])

  workspaceId String? @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  permissionId String   @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id])

  grantedById String? @map("granted_by") @db.Uuid
  grantedBy   Identity? @relation("PermissionGrantedBy", fields: [grantedById], references: [id])

  revokedById String? @map("revoked_by") @db.Uuid
  revokedBy   Identity? @relation("PermissionRevokedBy", fields: [revokedById], references: [id])

  effect      PermissionEffect @default(ALLOW)

  source      PermissionSource @default(MANUAL)
  isActive    Boolean          @default(true) @map("is_active")
  isTemporary Boolean          @default(false) @map("is_temporary")
  expiresAt   DateTime?        @map("expires_at")

  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([permissionId])
  @@index([identityId, workspaceId, isActive])
  @@index([expiresAt])
  @@index([identityId, workspaceId, effect])
}

// Admin audit logs
model AdminAuditLog {
  id String @id @default(uuid()) @db.Uuid

  adminIdentityId String @map("admin_identity_id") @db.Uuid
  adminIdentity   Identity @relation(fields: [adminIdentityId], references: [id])

  workspaceId String? @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  adminEmail String? @map("admin_email")
  adminRole  String? @map("admin_role")

  action     String
  entityType String @map("entity_type")
  entityId   String @map("entity_id") @db.Uuid

  description String?
  oldValue    Json?   @map("old_value")
  newValue    Json?   @map("new_value")

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  requestId String? @map("request_id")

  source   AuditSource   @default(ADMIN_PANEL)
  severity AuditSeverity @default(INFO)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminIdentityId])
  @@index([entityType, entityId])
  @@index([workspaceId, createdAt])
  @@index([createdAt])
  @@index([severity])
}
// Support / notifications / pages / blogs placeholders (kept from original)
model SupportTicket {
  id String @id @default(uuid()) @db.Uuid
  workspaceId String? @map("workspace_id") @db.Uuid
  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  createdByCustomerId String? @map("created_by_customer_id") @db.Uuid
  createdByCustomer Customer? @relation("CreatedCustomerTickets", fields: [createdByCustomerId], references: [id])
  
  contextType SupportContextType @map("context_type")

  createdById String? @map("created_by") @db.Uuid
  createdBy Identity? @relation("CreatedTickets", fields: [createdById], references: [id])

  assignedToId String? @map("assigned_to") @db.Uuid
  assignedTo Identity? @relation("AssignedTickets", fields: [assignedToId], references: [id])

  title String
  body  String
  status String
  priority String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  messages SupportTicketMessage[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([contextType, createdAt])
  @@index([createdById])
  @@index([createdByCustomerId])
  @@index([assignedToId])
}

model SupportTicketMessage {
  id       String @id @default(uuid()) @db.Uuid
  ticketId String @map("ticket_id") @db.Uuid

  workspaceId String? @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  senderIdentityId String? @map("sender_identity_id") @db.Uuid
  senderIdentity Identity? @relation("SentMessages", fields: [senderIdentityId], references: [id])
  senderCustomerId String? @map("sender_customer_id") @db.Uuid
  senderCustomer Customer? @relation(fields: [senderCustomerId], references: [id])

  senderType SenderType @map("sender_type")

  message        String
  isInternalNote Boolean  @default(false) @map("is_internal_note")
  attachments    Json?
  createdAt      DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id])

  @@index([ticketId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([senderIdentityId, createdAt])
  @@index([senderCustomerId, createdAt])
}

model Notification {
  id String @id @default(uuid()) @db.Uuid
  workspaceId String? @map("workspace_id") @db.Uuid
  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  recipientIdentityId String? @map("recipient_identity_id") @db.Uuid
  recipientIdentity Identity? @relation(fields: [recipientIdentityId], references: [id])

  recipientCustomerId String? @map("recipient_customer_id") @db.Uuid
  recipientCustomer Customer? @relation(fields: [recipientCustomerId], references: [id])

  targetType NotificationTargetType @map("target_type")
  channel String
  payload Json
  isRead Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@index([recipientIdentityId, isRead, createdAt])
  @@index([recipientCustomerId, isRead, createdAt])
  @@index([workspaceId, isRead, createdAt])
}

// -------------------- ENTITLEMENTS -------------------- //

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?

  isActive    Boolean  @default(true) @map("is_active")
  isPublic    Boolean  @default(true) @map("is_public")
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  features    PlanFeature[]
  limits      PlanLimit[]
  products Product[]

  @@index([isActive])
  @@index([sortOrder])
}

model Feature {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  category    String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  planFeatures PlanFeature[]
  workspaceOverrides WorkspaceFeatureOverride[]

  @@index([category, isActive])
  @@index([sortOrder])
}

model LimitDefinition {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  unit        String?  // e.g. users, projects, GB, seats

  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  planLimits   PlanLimit[]
  workspaceOverrides WorkspaceLimitOverride[]

  @@index([isActive])
  @@index([unit])
  @@index([sortOrder])
}

model PlanFeature {
  id         String   @id @default(uuid()) @db.Uuid

  planId     String   @map("plan_id") @db.Uuid
  plan       Plan     @relation(fields: [planId], references: [id])

  featureId  String   @map("feature_id") @db.Uuid
  feature    Feature  @relation(fields: [featureId], references: [id])

  isEnabled  Boolean  @default(true) @map("is_enabled")

  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([planId, featureId])
  @@index([featureId])
  @@index([planId, isEnabled])
}

model PlanLimit {
  id               String   @id @default(uuid()) @db.Uuid

  planId           String   @map("plan_id") @db.Uuid
  plan             Plan     @relation(fields: [planId], references: [id])

  limitDefinitionId String  @map("limit_definition_id") @db.Uuid
  limitDefinition   LimitDefinition @relation(fields: [limitDefinitionId], references: [id])

  valueInt         Int      @map("value_int")

  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([planId, limitDefinitionId])
  @@index([limitDefinitionId])
  @@index([planId])
}

model WorkspaceFeatureOverride {
  id          String   @id @default(uuid()) @db.Uuid

  workspaceId  String   @map("workspace_id") @db.Uuid
  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  featureId    String   @map("feature_id") @db.Uuid
  feature      Feature  @relation(fields: [featureId], references: [id])

  isEnabled    Boolean  @map("is_enabled")

  source       EntitlementSource @default(MANUAL)
  reason       String?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, featureId])
  @@index([workspaceId])
  @@index([featureId])
}

model WorkspaceLimitOverride {
  id               String   @id @default(uuid()) @db.Uuid

  workspaceId      String   @map("workspace_id") @db.Uuid
  workspace        Workspace @relation(fields: [workspaceId], references: [id])

  limitDefinitionId String  @map("limit_definition_id") @db.Uuid
  limitDefinition   LimitDefinition @relation(fields: [limitDefinitionId], references: [id])

  valueInt         Int      @map("value_int")

  source           EntitlementSource @default(MANUAL)
  reason           String?

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, limitDefinitionId])
  @@index([workspaceId])
  @@index([limitDefinitionId])
}

model Product {
  id String @id @default(uuid()) @db.Uuid

  name String
  code String @unique

  planId String? @db.Uuid @map("plan_id") // link to entitlements
  plan   Plan? @relation(fields: [planId], references: [id])

  type ProductType
  description String?

  isActive Boolean @default(true) @map("is_active")  

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  prices Price[]
  invoiceItems InvoiceItem[]

  @@index([planId])
  @@index([isActive]) 
}

model Price {
  id String @id @default(uuid()) @db.Uuid

  productId String @db.Uuid @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  amount   Int
  currency Currency @default(INR)

  interval BillingInterval? // null = one-time

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]
  payments Payment[]
  invoiceItems InvoiceItem[]

  @@index([productId])
  @@index([productId, isActive])
}

model Subscription {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String? @db.Uuid @map("workspace_id") // nullable for B2C saas where subscription is directly linked to an end-user identity
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  identityId String? @db.Uuid @map("identity_id") // for B2C saas where subscription is directly linked to an end-user identity
  identity   Identity? @relation(fields: [identityId], references: [id])

  customerId String? @db.Uuid @map("customer_id") // for B2B2C saas where subscription is linked to a customer (end-user) within a workspace
  customer   Customer? @relation(fields: [customerId], references: [id])

  priceId String @db.Uuid @map("price_id")
  price   Price @relation(fields: [priceId], references: [id])

  status SubscriptionStatus

  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")

  cancelAtPeriodEnd Boolean @default(false)

  provider PaymentProvider
  providerSubscriptionId String? @map("provider_subscription_id") @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payments Payment[]

  @@index([workspaceId])
  @@index([status])
  @@index([identityId, status])
  @@index([customerId, status])
  @@index([workspaceId, status])
  @@index([priceId])  
}

model Payment {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String? @db.Uuid @map("workspace_id") // B2B saas and B2B2C saas where payment is linked to a workspace
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  identityId String? @db.Uuid @map("identity_id") // for B2C saas where payment is directly linked to an end-user identity
  identity   Identity? @relation(fields: [identityId], references: [id])

  customerId String? @db.Uuid @map("customer_id") // for B2B2C saas where payment is linked to a customer (end-user) within a workspace
  customer   Customer? @relation(fields: [customerId], references: [id])

  priceId String? @db.Uuid @map("price_id")
  price   Price? @relation(fields: [priceId], references: [id])

  subscriptionId String? @db.Uuid @map("subscription_id")
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  type PaymentType  @default(ONE_TIME)

  paymentProvider PaymentProvider @map("payment_provider") @default(RAZORPAY)

  providerOrderId   String? @map("provider_order_id") @unique
  providerPaymentId String? @map("provider_payment_id") @unique
  providerSignature String? @map("provider_signature") 

  amount   Decimal @db.Decimal(12, 2)
  currency Currency @default(INR)

  paymentStatus PaymentStatus @map("payment_status") @default(PENDING)

  description String?
  metadata Json?

  capturedAt DateTime? @map("captured_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  attempts PaymentAttempt[]
  refunds  Refund[]
  invoices Invoice[]

  @@index([workspaceId])
  @@index([paymentStatus, createdAt])
  @@index([identityId, createdAt])
  @@index([customerId, createdAt])
  @@index([subscriptionId])
  @@index([workspaceId, paymentStatus])
  @@index([identityId, paymentStatus])
}

model PaymentAttempt {
  id String @id @default(uuid()) @db.Uuid

  paymentId String @db.Uuid @map("payment_id")
  payment   Payment @relation(fields: [paymentId], references: [id])

  attemptNumber Int @map("attempt_number") // for multiple attempts on the same payment

  provider PaymentProvider @map("payment_provider") @default(RAZORPAY)

  requestPayload  Json? @map("request_payload")
  responsePayload Json? @map("response_payload")

  status       String?
  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([paymentId])
  @@unique([paymentId, attemptNumber])
  @@index([paymentId, createdAt])
}

model Invoice {
  id String @id @default(uuid()) @db.Uuid

  paymentId String? @db.Uuid @map("payment_id")
  payment   Payment? @relation(fields: [paymentId], references: [id])

  workspaceId String? @db.Uuid @map("workspace_id") // nullable for B2C saas where invoice is directly linked to an end-user identity
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  identityId String? @db.Uuid @map("identity_id") // for B2C saas where invoice is directly linked to an end-user identity
  identity   Identity? @relation(fields: [identityId], references: [id])

  customerId String? @db.Uuid @map("customer_id") // for B2B2C saas where invoice is linked to a customer (end-user) within a workspace
  customer   Customer? @relation(fields: [customerId], references: [id])

  invoiceNumber String @unique @map("invoice_number")

  amount   Decimal @db.Decimal(12, 2)
  currency Currency @default(INR)

  status PaymentStatus @default(PENDING)

  issuedAt DateTime @default(now()) @map("issued_at")
  paidAt   DateTime? @map("paid_at")

  billingAddress  Json? @map("billing_address")
  shippingAddress Json? @map("shipping_address")

  createdAt DateTime @default(now()) @map("created_at")

  items InvoiceItem[]

  @@index([workspaceId])
  @@index([identityId, createdAt])
  @@index([customerId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([paymentId])
}

model InvoiceItem {
  id String @id @default(uuid()) @db.Uuid

  invoiceId String @db.Uuid @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  productId String? @db.Uuid @map("product_id")
  product   Product? @relation(fields: [productId], references: [id])

  priceId String? @db.Uuid @map("price_id")
  price   Price? @relation(fields: [priceId], references: [id])

  quantity Int

  unitPrice Decimal @db.Decimal(12, 2) @map("unit_price")
  total     Decimal @db.Decimal(12, 2)
  currency  Currency @default(INR)

  metadata Json?

  @@index([invoiceId])
}

model Refund {
  id String @id @default(uuid()) @db.Uuid

  paymentId String @db.Uuid @map("payment_id")
  payment   Payment @relation(fields: [paymentId], references: [id])

  amount   Decimal @db.Decimal(12, 2)
  currency Currency @default(INR)

  status RefundStatus @default(PENDING)

  reason RefundReason? @default(USER_REQUEST)
  notes  String?

  paymentProvider PaymentProvider @map("payment_provider") @default(RAZORPAY) 

  providerRefundId String? @map("provider_refund_id") @unique

  metadata Json?

  processedAt DateTime? @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([paymentId])
  @@index([status])
}