// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleScope {
  WORKSPACE
  PLATFORM
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum WorkspaceDomainType {
  SUBDOMAIN
  CUSTOM
}

enum WorkspaceDomainStatus {
  PENDING_VERIFICATION
  VERIFIED
  FAILED
  DISABLED
}

enum WorkspaceDomainRoutingMode {
  CNAME
  APEX_A
}

enum DnsRecordType {
  A
  AAAA
  CNAME
  TXT
  CAA
  MX
}

enum DomainVerificationPurpose {
  OWNERSHIP
  ROUTING
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  INVITE
  PASSWORD_RESET
  MFA
}

enum AuthAccountType {
  EMAIL
  PHONE
}

enum SessionEndReason {
  LOGOUT
  EXPIRED
  REVOKED
  REPLACED
}

enum SenderType {
  IDENTITY
  CUSTOMER
  SYSTEM
}

enum PermissionSource {
  MANUAL
  INHERITED
  SYSTEM
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum AuditSource {
  ADMIN_PANEL
  WORKSPACE_APP
  CUSTOMER_APP
  AUTH
  API
  WEBHOOK
  JOB
  SYSTEM
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
}

enum AuditScope {
  PLATFORM
  WORKSPACE
  CUSTOMER
  SYSTEM
}

enum AuditActorType {
  IDENTITY
  CUSTOMER
  API_KEY
  SYSTEM
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

enum AuditCategory {
  AUTH
  GOVERNANCE
  CATALOG
  BILLING
  WORKSPACE
  CUSTOMER
  SUPPORT
  NOTIFICATION
  ROUTING
  MEDIA
  INTEGRATION
  ENTITLEMENT
  SECURITY
  SYSTEM
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_SAY
}

enum NotificationTargetType {
  IDENTITY
  CUSTOMER
  BOTH
  WORKSPACE
  PLATFORM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationDeliveryStatus {
  PENDING
  PROCESSING
  SENT
  DELIVERED
  FAILED
  CANCELLED
}

enum SupportContextType {
  PLATFORM
  WORKSPACE
  CUSTOMER
}

enum EntitlementSource {
  PLAN
  MANUAL
  SYSTEM
}

enum EntitlementOverridePolicy {
  NEVER
  PLATFORM_ONLY
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCESS
  FAILED
  CANCELLED
}

enum PaymentType {
  SIGNUP
  UPGRADE
  DOWNGRADE
  RENEWAL
  ONE_TIME
  ADDON
}

enum ProductType {
  SUBSCRIPTION
  ONE_TIME
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  EXPIRED
  TRIALING
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum RefundReason {
  USER_REQUEST
  DUPLICATE
  FRAUD
  PAYMENT_ERROR
  UPGRADE_ADJUSTMENT
  DOWNGRADE_ADJUSTMENT
  OTHER
}

enum Currency {
  USD
  EUR
  GBP
  INR
  AUD
  CAD
}

enum WebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum MediaStatus {
  UPLOADING // (optional) presigned flow started but not confirmed
  UPLOADED // file successfully uploaded to storage (B2)

  PROCESSING // async jobs running (resize, scan, etc.)
  READY // fully processed and usable (CDN ready)

  FAILED // processing failed
  DELETED // soft delete (logical removal)
}

enum MediaJobStatus {
  PENDING
  DONE
  FAILED
}

// -------------------- CORE MODELS --------------------

// Workspace (previously Tenant)
model Workspace {
  id            String  @id @default(uuid()) @db.Uuid
  name          String
  slug          String  @unique
  defaultDomain String? @map("default_domain")
  primaryEmail  String? @map("primary_email")
  isActive      Boolean @default(true) @map("is_active")

  // Multi-domain support
  domains WorkspaceDomain[]

  // members & roles
  memberships Membership[]

  // customers (end-users of a workspace product)
  customers Customer[]

  // auth
  otpRequests OtpRequest[]
  sessions    Session[]

  // settings & history
  settings WorkspaceSettings?

  // permissions
  userPermissions          UserPermission[]
  workspaceRolePermissions WorkspaceRolePermission[]

  // invites
  invites WorkspaceInvite[]

  // api keys
  apiKeys ApiKey[]

  // support
  supportTickets  SupportTicket[]
  supportMessages SupportTicketMessage[]

  // notifications
  notifications          Notification[]
  notificationDeliveries NotificationDelivery[]

  // features & limits
  featureOverrides WorkspaceFeatureOverride[]
  limitOverrides   WorkspaceLimitOverride[]

  // billing
  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]

  // audit / webhooks
  auditEvents AuditEvent[]

  webhookEvents   WebhookEvent[]
  outboxEvents    OutboxEvent[]
  media           Media[]
  fileAttachments FileAttachment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([createdAt])
  @@index([primaryEmail])
}

// workspace domains (CNAMEs / custom domains)
model WorkspaceDomain {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  domain                String // e.g. workspace.com or acme.platform.com
  type                  WorkspaceDomainType        @default(CUSTOM)
  routingMode           WorkspaceDomainRoutingMode @default(CNAME) @map("routing_mode")
  status                WorkspaceDomainStatus      @default(PENDING_VERIFICATION)
  target                String?
  verificationToken     String?                    @unique @map("verification_token")
  isPrimary             Boolean                    @default(false) @map("is_primary")
  isVerified            Boolean                    @default(false) @map("is_verified")
  verifiedAt            DateTime?                  @map("verified_at")
  lastCheckedAt         DateTime?                  @map("last_checked_at")
  lastVerificationError String?                    @map("last_verification_error")

  dnsRecords WorkspaceDomainDnsRecord[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([domain])
  @@index([workspaceId, isPrimary])
  @@index([workspaceId, status])
}

model WorkspaceDomainDnsRecord {
  id                String          @id @default(uuid()) @db.Uuid
  workspaceDomainId String          @map("workspace_domain_id") @db.Uuid
  workspaceDomain   WorkspaceDomain @relation(fields: [workspaceDomainId], references: [id], onDelete: Cascade)

  type          DnsRecordType
  purpose       DomainVerificationPurpose
  host          String
  expectedValue String                    @map("expected_value")
  isRequired    Boolean                   @default(true) @map("is_required")
  isMatched     Boolean                   @default(false) @map("is_matched")
  matchedValue  String?                   @map("matched_value")
  lastCheckedAt DateTime?                 @map("last_checked_at")
  lastError     String?                   @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([workspaceDomainId, type, host, expectedValue])
  @@index([workspaceDomainId, purpose])
}

// memberships: join table Identity <-> Workspace (many-to-many)
model RoleDefinition {
  id            String    @id @default(uuid()) @db.Uuid
  scope         RoleScope
  key           String
  name          String
  description   String?
  isSystem      Boolean   @default(false) @map("is_system")
  systemKey     String?   @map("system_key")
  hierarchyRank Int?      @map("hierarchy_rank")
  isDefault     Boolean   @default(false) @map("is_default")
  isAssignable  Boolean   @default(true) @map("is_assignable")
  isActive      Boolean   @default(true) @map("is_active")

  workspaceMemberships     Membership[]              @relation("WorkspaceMembershipRoleDefinition")
  workspaceInvites         WorkspaceInvite[]         @relation("WorkspaceInviteRoleDefinition")
  platformMemberships      PlatformMembership[]      @relation("PlatformMembershipRoleDefinition")
  platformInvites          PlatformInvite[]          @relation("PlatformInviteRoleDefinition")
  sessionWorkspaceRoles    Session[]                 @relation("SessionWorkspaceRoleDefinition")
  rolePermissions          RolePermission[]
  workspaceRolePermissions WorkspaceRolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([scope, key])
  @@unique([scope, systemKey])
  @@index([scope, isActive])
}

model Membership {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  roleDefinitionId String         @map("role_definition_id") @db.Uuid
  roleDefinition   RoleDefinition @relation("WorkspaceMembershipRoleDefinition", fields: [roleDefinitionId], references: [id])
  roleKey          String         @map("role_key")
  roleSystemKey    String?        @map("role_system_key")
  isActive         Boolean        @default(true) @map("is_active")

  sessions  Session[]
  // optional temporary access expiry
  expiresAt DateTime? @map("expires_at")

  version Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, identityId])
  @@index([identityId])
  @@index([workspaceId, roleDefinitionId])
  @@index([workspaceId, roleSystemKey])
}

// Workspace invites (separate from Membership)
model WorkspaceInvite {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  email            String
  roleDefinitionId String         @map("role_definition_id") @db.Uuid
  roleDefinition   RoleDefinition @relation("WorkspaceInviteRoleDefinition", fields: [roleDefinitionId], references: [id])
  roleKey          String         @map("role_key")
  roleSystemKey    String?        @map("role_system_key")
  invitedById      String?        @map("invited_by") @db.Uuid
  invitedBy        Identity?      @relation(fields: [invitedById], references: [id])

  token     String       @unique
  status    InviteStatus @default(PENDING)
  expiresAt DateTime?
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([workspaceId, status])
  @@index([token, workspaceId])
  @@index([email, workspaceId])
  @@index([workspaceId, roleDefinitionId])
}

model WorkspaceSettings {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  themes Json // free-form JSON for theme settings (colors, fonts, etc.)

  settings Json // free-form JSON for extensible settings (branding, flags)

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([workspaceId])
}

model Identity {
  id        String  @id @default(uuid()) @db.Uuid
  firstName String? @map("first_name") @db.VarChar(255)
  lastName  String? @map("last_name") @db.VarChar(255)

  email String? @unique
  phone String? @unique

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authAccounts  AuthAccount[]
  oauthAccounts OAuthAccount[]
  sessions      Session[]

  platformInvites     PlatformInvite[]
  platformMemberships PlatformMembership[]

  memberships        Membership[]
  customers          Customer[]
  permissions        UserPermission[]  @relation("UserPermissions")
  permissionsGranted UserPermission[]  @relation("PermissionGrantedBy")
  permissionsRevoked UserPermission[]  @relation("PermissionRevokedBy")
  auditActorEvents   AuditEvent[]      @relation("AuditActorIdentity")
  invites            WorkspaceInvite[]
  apiKeys            ApiKey[]

  sentTickets     SupportTicket[]        @relation("CreatedTickets")
  supportMessages SupportTicketMessage[] @relation("SentMessages")
  assignedTickets SupportTicket[]        @relation("AssignedTickets")
  notifications   Notification[]

  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]

  webhookEvents   WebhookEvent[]
  outboxEvents    OutboxEvent[]
  media           Media[]
  fileAttachments FileAttachment[]
}

model AuthAccount {
  id String @id @default(uuid()) @db.Uuid

  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  type  AuthAccountType // EMAIL | PHONE
  value String // email address or phone number

  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")

  passwordHash String? @map("password_hash")

  createdAt DateTime @default(now()) @map("created_at")

  optRequests OtpRequest[]

  @@unique([type, value])
  @@index([identityId])
  @@index([identityId, type])
}

// OAuth linked accounts for Identities (Google, etc.)
model OAuthAccount {
  id String @id @default(uuid()) @db.Uuid

  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  provider          String // 'google', 'github', etc.
  providerAccountId String  @map("provider_account_id")
  accessToken       String? @map("access_token")
  refreshToken      String? @map("refresh_token")
  scope             String?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([provider, providerAccountId])
  @@index([identityId])
}

// Customers (end-users of a workspace product)
model Customer {
  id String @id @default(uuid()) @db.Uuid

  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  externalId String? @map("external_id") // for external systems

  notifications   Notification[]
  sessions        Session[]
  subscriptions   Subscription[]
  payments        Payment[]
  invoices        Invoice[]
  supportTickets  SupportTicket[]        @relation("CreatedCustomerTickets")
  supportMessages SupportTicketMessage[]
  auditActorEvents   AuditEvent[]        @relation("AuditActorCustomer")
  auditSubjectEvents AuditEvent[]        @relation("AuditSubjectCustomer")

  webhookEvents   WebhookEvent[]
  outboxEvents    OutboxEvent[]
  media           Media[]
  fileAttachments FileAttachment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, identityId])
  @@index([workspaceId])
}

// API keys (tenant/workspace scoped)
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  name        String    @default("API Key")
  key         String?   @unique // legacy raw secret during transition to hash-only storage
  keyPrefix   String?   @map("key_prefix")
  keyHash     String?   @unique @map("key_hash")
  description String?
  scopes      String[] // e.g. ["orders:read","orders:write"]
  createdById String?   @map("created_by") @db.Uuid
  createdBy   Identity? @relation(fields: [createdById], references: [id])

  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime?
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  auditActorEvents AuditEvent[] @relation("AuditActorApiKey")

  @@index([workspaceId, isActive])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, lastUsedAt])
  @@index([createdById])
  @@index([keyPrefix])
}

// OTP requests (for email/phone OTP)
model OtpRequest {
  id            String      @id @default(uuid()) @db.Uuid
  authAccountId String      @map("auth_account_id") @db.Uuid
  authAccount   AuthAccount @relation(fields: [authAccountId], references: [id])

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  verificationId String     @unique @map("verification_id") @db.Uuid
  otpPurpose     OtpPurpose @map("otp_purpose")
  otpHash        String     @map("otp_hash")
  expiresAt      DateTime   @map("expires_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  attempts       Int        @default(0) @db.SmallInt
  resendCount    Int        @default(0) @map("resend_count") @db.SmallInt

  @@index([authAccountId, otpPurpose, createdAt])
  @@index([expiresAt])
}

// Sessions 
model Session {
  id String @id @default(uuid()) @db.Uuid

  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  // workspace context - nullable for platform-wide sessions
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  customerId String?   @map("customer_id") @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  membershipId String?     @map("membership_id") @db.Uuid
  membership   Membership? @relation(fields: [membershipId], references: [id])

  workspaceRoleDefinitionId String?         @map("workspace_role_definition_id") @db.Uuid
  workspaceRoleDefinition   RoleDefinition? @relation("SessionWorkspaceRoleDefinition", fields: [workspaceRoleDefinitionId], references: [id])
  workspaceRoleKey          String?         @map("workspace_role_key")
  workspaceRoleSystemKey    String?         @map("workspace_role_system_key")

  ip                String?
  browser           String?
  os                String?
  device            String?
  deviceId          String? @map("device_id")
  deviceFingerprint String? @map("device_fingerprint")
  userAgent         String? @map("user_agent")

  isActive Boolean @default(true) @map("is_active")

  expiresAt   DateTime          @map("expires_at")
  endedAt     DateTime?         @map("ended_at")
  endedReason SessionEndReason? @map("ended_reason")

  lastSeenAt DateTime? @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")

  auditEvents AuditEvent[] @relation("AuditSession")

  @@index([identityId, isActive, createdAt])
  @@index([workspaceId, isActive, createdAt])
  @@index([isActive, expiresAt])
  @@index([deviceId])
  @@index([deviceFingerprint])
  @@index([customerId])
  @@index([membershipId])
  @@index([workspaceId])
  @@index([workspaceRoleDefinitionId])
}

model PlatformInvite {
  id String @id @default(uuid()) @db.Uuid

  email            String
  roleDefinitionId String         @map("role_definition_id") @db.Uuid
  roleDefinition   RoleDefinition @relation("PlatformInviteRoleDefinition", fields: [roleDefinitionId], references: [id])
  roleKey          String         @map("role_key")
  roleSystemKey    String?        @map("role_system_key")

  invitedById String?   @map("invited_by") @db.Uuid
  invitedBy   Identity? @relation(fields: [invitedById], references: [id])

  token     String       @unique
  status    InviteStatus @default(PENDING)
  expiresAt DateTime?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, status])
  @@index([token])
  @@index([roleDefinitionId])
}

model PlatformMembership {
  id String @id @default(uuid()) @db.Uuid

  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation(fields: [identityId], references: [id])

  roleDefinitionId String         @map("role_definition_id") @db.Uuid
  roleDefinition   RoleDefinition @relation("PlatformMembershipRoleDefinition", fields: [roleDefinitionId], references: [id])
  roleKey          String         @map("role_key")
  roleSystemKey    String?        @map("role_system_key")

  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([identityId, roleDefinitionId])
  @@index([identityId, isActive])
  @@index([identityId, roleSystemKey])
}

// Permission models
model Permission {
  id String @id @default(uuid()) @db.Uuid

  key         String  @unique
  name        String?
  description String?
  entity      String
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userPermissions          UserPermission[]
  rolePermissions          RolePermission[]
  workspaceRolePermissions WorkspaceRolePermission[]

  @@index([entity])
  @@index([entity, isActive])
}

model RolePermission {
  id String @id @default(uuid()) @db.Uuid

  roleDefinitionId String         @map("role_definition_id") @db.Uuid
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id])

  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([roleDefinitionId, permissionId])
  @@index([roleDefinitionId])
  @@index([permissionId])
}

model WorkspaceRolePermission {
  id String @id @default(uuid()) @db.Uuid

  workspaceId      String         @map("workspace_id") @db.Uuid
  workspace        Workspace      @relation(fields: [workspaceId], references: [id])
  roleDefinitionId String         @map("role_definition_id") @db.Uuid
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id])

  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id])

  isAllowed Boolean @default(true)

  @@unique([workspaceId, roleDefinitionId, permissionId])
  @@index([workspaceId, roleDefinitionId])
  @@index([permissionId])
}

model UserPermission {
  id String @id @default(uuid()) @db.Uuid

  identityId String   @map("identity_id") @db.Uuid
  identity   Identity @relation("UserPermissions", fields: [identityId], references: [id])

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id])

  grantedById String?   @map("granted_by") @db.Uuid
  grantedBy   Identity? @relation("PermissionGrantedBy", fields: [grantedById], references: [id])

  revokedById String?   @map("revoked_by") @db.Uuid
  revokedBy   Identity? @relation("PermissionRevokedBy", fields: [revokedById], references: [id])

  effect PermissionEffect @default(ALLOW)

  source      PermissionSource @default(MANUAL)
  isActive    Boolean          @default(true) @map("is_active")
  isTemporary Boolean          @default(false) @map("is_temporary")
  expiresAt   DateTime?        @map("expires_at")

  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([permissionId])
  @@index([identityId, workspaceId, isActive])
  @@index([expiresAt])
  @@index([identityId, workspaceId, effect])
}

model AuditEvent {
  id String @id @default(uuid()) @db.Uuid

  scope    AuditScope
  category AuditCategory
  source   AuditSource   @default(ADMIN_PANEL)
  outcome  AuditOutcome  @default(SUCCESS)
  severity AuditSeverity @default(INFO)

  action     String
  entityType String  @map("entity_type")
  entityId   String? @map("entity_id")

  description String?
  reason      String?

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  customerId String?   @map("customer_id") @db.Uuid
  customer   Customer? @relation("AuditSubjectCustomer", fields: [customerId], references: [id])

  actorType AuditActorType @map("actor_type")

  actorIdentityId String?   @map("actor_identity_id") @db.Uuid
  actorIdentity   Identity? @relation("AuditActorIdentity", fields: [actorIdentityId], references: [id])

  actorCustomerId String?   @map("actor_customer_id") @db.Uuid
  actorCustomer   Customer? @relation("AuditActorCustomer", fields: [actorCustomerId], references: [id])

  actorApiKeyId String?  @map("actor_api_key_id") @db.Uuid
  actorApiKey   ApiKey?  @relation("AuditActorApiKey", fields: [actorApiKeyId], references: [id])

  sessionId String?  @map("session_id") @db.Uuid
  session   Session? @relation("AuditSession", fields: [sessionId], references: [id])

  actorEmail         String? @map("actor_email")
  actorName          String? @map("actor_name")
  actorPlatformRole  String? @map("actor_platform_role")
  actorWorkspaceRole String? @map("actor_workspace_role")

  requestId     String? @map("request_id")
  ipAddress     String? @map("ip_address")
  userAgent     String? @map("user_agent")
  requestPath   String? @map("request_path")
  requestMethod String? @map("request_method")

  oldValue Json? @map("old_value")
  newValue Json? @map("new_value")
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([scope, createdAt])
  @@index([category, createdAt])
  @@index([source, createdAt])
  @@index([outcome, createdAt])
  @@index([severity, createdAt])
  @@index([workspaceId, createdAt])
  @@index([customerId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([actorIdentityId, createdAt])
  @@index([actorCustomerId, createdAt])
  @@index([actorApiKeyId, createdAt])
  @@index([sessionId])
  @@index([requestId])
}

// Support / notifications / pages / blogs placeholders (kept from original)
model SupportTicket {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  createdByCustomerId String?   @map("created_by_customer_id") @db.Uuid
  createdByCustomer   Customer? @relation("CreatedCustomerTickets", fields: [createdByCustomerId], references: [id])

  contextType SupportContextType @map("context_type")

  createdById String?   @map("created_by") @db.Uuid
  createdBy   Identity? @relation("CreatedTickets", fields: [createdById], references: [id])

  assignedToId String?   @map("assigned_to") @db.Uuid
  assignedTo   Identity? @relation("AssignedTickets", fields: [assignedToId], references: [id])

  title    String
  body     String
  status   String
  priority String?

  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")
  messages  SupportTicketMessage[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([contextType, createdAt])
  @@index([createdById])
  @@index([createdByCustomerId])
  @@index([assignedToId])
}

model SupportTicketMessage {
  id       String @id @default(uuid()) @db.Uuid
  ticketId String @map("ticket_id") @db.Uuid

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  senderIdentityId String?   @map("sender_identity_id") @db.Uuid
  senderIdentity   Identity? @relation("SentMessages", fields: [senderIdentityId], references: [id])
  senderCustomerId String?   @map("sender_customer_id") @db.Uuid
  senderCustomer   Customer? @relation(fields: [senderCustomerId], references: [id])

  senderType SenderType @map("sender_type")

  message        String
  isInternalNote Boolean  @default(false) @map("is_internal_note")
  attachments    Json?
  createdAt      DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id])

  @@index([ticketId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([senderIdentityId, createdAt])
  @@index([senderCustomerId, createdAt])
}

model Notification {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  recipientIdentityId String?   @map("recipient_identity_id") @db.Uuid
  recipientIdentity   Identity? @relation(fields: [recipientIdentityId], references: [id])

  recipientCustomerId String?   @map("recipient_customer_id") @db.Uuid
  recipientCustomer   Customer? @relation(fields: [recipientCustomerId], references: [id])

  type       String
  targetType NotificationTargetType @map("target_type")
  title      String?
  body       String?
  payload    Json
  isRead     Boolean                @default(false) @map("is_read")
  readAt     DateTime?              @map("read_at")

  deliveries NotificationDelivery[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@index([recipientIdentityId, isRead, createdAt])
  @@index([recipientCustomerId, isRead, createdAt])
  @@index([workspaceId, isRead, createdAt])
}

model NotificationDelivery {
  id String @id @default(uuid()) @db.Uuid

  notificationId String       @map("notification_id") @db.Uuid
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  channel  NotificationChannel
  provider String?
  status   NotificationDeliveryStatus @default(PENDING)

  recipient String
  subject   String?
  content   String?
  payload   Json?

  providerMessageId String? @map("provider_message_id")
  errorMessage      String? @map("error_message")

  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  failedAt    DateTime? @map("failed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([notificationId])
  @@index([workspaceId, createdAt])
  @@index([status, createdAt])
  @@index([channel, status])
}

// -------------------- ENTITLEMENTS -------------------- //

model Plan {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  name        String
  description String?

  isActive  Boolean @default(true) @map("is_active")
  isPublic  Boolean @default(true) @map("is_public")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  features PlanFeature[]
  limits   PlanLimit[]
  products Product[]

  @@index([isActive])
  @@index([sortOrder])
}

model Feature {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  name        String
  description String?
  category    String?
  isActive    Boolean @default(true) @map("is_active")
  overridePolicy EntitlementOverridePolicy @default(PLATFORM_ONLY) @map("override_policy")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  planFeatures       PlanFeature[]
  workspaceOverrides WorkspaceFeatureOverride[]

  @@index([category, isActive])
  @@index([sortOrder])
}

model LimitDefinition {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  name        String
  description String?
  unit        String? // e.g. users, projects, GB, seats

  isActive  Boolean @default(true) @map("is_active")
  overridePolicy EntitlementOverridePolicy @default(PLATFORM_ONLY) @map("override_policy")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  planLimits         PlanLimit[]
  workspaceOverrides WorkspaceLimitOverride[]

  @@index([isActive])
  @@index([unit])
  @@index([sortOrder])
}

model PlanFeature {
  id String @id @default(uuid()) @db.Uuid

  planId String @map("plan_id") @db.Uuid
  plan   Plan   @relation(fields: [planId], references: [id])

  featureId String  @map("feature_id") @db.Uuid
  feature   Feature @relation(fields: [featureId], references: [id])

  isEnabled Boolean @default(true) @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([planId, featureId])
  @@index([featureId])
  @@index([planId, isEnabled])
}

model PlanLimit {
  id String @id @default(uuid()) @db.Uuid

  planId String @map("plan_id") @db.Uuid
  plan   Plan   @relation(fields: [planId], references: [id])

  limitDefinitionId String          @map("limit_definition_id") @db.Uuid
  limitDefinition   LimitDefinition @relation(fields: [limitDefinitionId], references: [id])

  valueInt Int @map("value_int")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([planId, limitDefinitionId])
  @@index([limitDefinitionId])
  @@index([planId])
}

model WorkspaceFeatureOverride {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  featureId String  @map("feature_id") @db.Uuid
  feature   Feature @relation(fields: [featureId], references: [id])

  isEnabled Boolean @map("is_enabled")

  source EntitlementSource @default(MANUAL)
  reason String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, featureId])
  @@index([workspaceId])
  @@index([featureId])
}

model WorkspaceLimitOverride {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  limitDefinitionId String          @map("limit_definition_id") @db.Uuid
  limitDefinition   LimitDefinition @relation(fields: [limitDefinitionId], references: [id])

  valueInt Int @map("value_int")

  source EntitlementSource @default(MANUAL)
  reason String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, limitDefinitionId])
  @@index([workspaceId])
  @@index([limitDefinitionId])
}

model Product {
  id String @id @default(uuid()) @db.Uuid

  name String
  code String @unique

  planId String? @map("plan_id") @db.Uuid // link to entitlements
  plan   Plan?   @relation(fields: [planId], references: [id])

  type        ProductType
  description String?

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  prices       Price[]
  invoiceItems InvoiceItem[]

  @@index([planId])
  @@index([isActive])
}

model Price {
  id String @id @default(uuid()) @db.Uuid

  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id])

  amount   Int
  currency Currency @default(INR)

  interval BillingInterval? // null = one-time

  providerPriceId String? @unique @map("provider_price_id") // for recurring provider references (e.g. Razorpay plan_id, Stripe price_id)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]
  payments      Payment[]
  invoiceItems  InvoiceItem[]

  @@index([productId])
  @@index([productId, isActive])
}

model Subscription {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String?    @map("workspace_id") @db.Uuid // nullable for B2C saas where subscription is directly linked to an end-user identity
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  identityId String?   @map("identity_id") @db.Uuid // for B2C saas where subscription is directly linked to an end-user identity
  identity   Identity? @relation(fields: [identityId], references: [id])

  customerId String?   @map("customer_id") @db.Uuid // for B2B2C saas where subscription is linked to a customer (end-user) within a workspace
  customer   Customer? @relation(fields: [customerId], references: [id])

  priceId String @map("price_id") @db.Uuid
  price   Price  @relation(fields: [priceId], references: [id])

  status SubscriptionStatus

  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")

  cancelAtPeriodEnd Boolean @default(false)

  provider               PaymentProvider
  providerSubscriptionId String?         @unique @map("provider_subscription_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payments Payment[]

  @@index([workspaceId])
  @@index([status])
  @@index([identityId, status])
  @@index([customerId, status])
  @@index([workspaceId, status])
  @@index([priceId])
}

model Payment {
  id String @id @default(uuid()) @db.Uuid

  workspaceId String?    @map("workspace_id") @db.Uuid // B2B saas and B2B2C saas where payment is linked to a workspace
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  identityId String?   @map("identity_id") @db.Uuid // for B2C saas where payment is directly linked to an end-user identity
  identity   Identity? @relation(fields: [identityId], references: [id])

  customerId String?   @map("customer_id") @db.Uuid // for B2B2C saas where payment is linked to a customer (end-user) within a workspace
  customer   Customer? @relation(fields: [customerId], references: [id])

  priceId String? @map("price_id") @db.Uuid
  price   Price?  @relation(fields: [priceId], references: [id])

  subscriptionId String?       @map("subscription_id") @db.Uuid
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  type PaymentType @default(ONE_TIME)

  paymentProvider PaymentProvider @default(RAZORPAY) @map("payment_provider")

  providerOrderId   String? @unique @map("provider_order_id")
  providerPaymentId String? @unique @map("provider_payment_id")
  providerSignature String? @map("provider_signature")

  amount   Decimal  @db.Decimal(12, 2)
  currency Currency @default(INR)

  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")

  description String?
  metadata    Json?

  capturedAt DateTime? @map("captured_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  attempts PaymentAttempt[]
  refunds  Refund[]
  invoices Invoice[]

  @@index([workspaceId])
  @@index([paymentStatus, createdAt])
  @@index([identityId, createdAt])
  @@index([customerId, createdAt])
  @@index([subscriptionId])
  @@index([workspaceId, paymentStatus])
  @@index([identityId, paymentStatus])
}

model PaymentAttempt {
  id String @id @default(uuid()) @db.Uuid

  paymentId String  @map("payment_id") @db.Uuid
  payment   Payment @relation(fields: [paymentId], references: [id])

  attemptNumber Int @map("attempt_number") // for multiple attempts on the same payment

  provider PaymentProvider @default(RAZORPAY) @map("payment_provider")

  requestPayload  Json? @map("request_payload")
  responsePayload Json? @map("response_payload")

  status       String?
  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([paymentId, attemptNumber])
  @@index([paymentId])
  @@index([paymentId, createdAt])
}

model Invoice {
  id String @id @default(uuid()) @db.Uuid

  paymentId String?  @map("payment_id") @db.Uuid
  payment   Payment? @relation(fields: [paymentId], references: [id])

  workspaceId String?    @map("workspace_id") @db.Uuid // nullable for B2C saas where invoice is directly linked to an end-user identity
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  identityId String?   @map("identity_id") @db.Uuid // for B2C saas where invoice is directly linked to an end-user identity
  identity   Identity? @relation(fields: [identityId], references: [id])

  customerId String?   @map("customer_id") @db.Uuid // for B2B2C saas where invoice is linked to a customer (end-user) within a workspace
  customer   Customer? @relation(fields: [customerId], references: [id])

  invoiceNumber     String  @unique @map("invoice_number")
  providerInvoiceId String? @unique @map("provider_invoice_id")

  amount   Decimal  @db.Decimal(12, 2)
  currency Currency @default(INR)

  status PaymentStatus @default(PENDING)

  issuedAt DateTime  @default(now()) @map("issued_at")
  paidAt   DateTime? @map("paid_at")

  billingAddress  Json? @map("billing_address")
  shippingAddress Json? @map("shipping_address")

  createdAt DateTime @default(now()) @map("created_at")

  items InvoiceItem[]

  @@index([workspaceId])
  @@index([identityId, createdAt])
  @@index([customerId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([paymentId])
}

model InvoiceItem {
  id String @id @default(uuid()) @db.Uuid

  invoiceId String  @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  productId String?  @map("product_id") @db.Uuid
  product   Product? @relation(fields: [productId], references: [id])

  priceId String? @map("price_id") @db.Uuid
  price   Price?  @relation(fields: [priceId], references: [id])

  quantity Int

  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  currency  Currency @default(INR)

  metadata Json?

  @@index([invoiceId])
}

model Refund {
  id String @id @default(uuid()) @db.Uuid

  paymentId String  @map("payment_id") @db.Uuid
  payment   Payment @relation(fields: [paymentId], references: [id])

  amount   Decimal  @db.Decimal(12, 2)
  currency Currency @default(INR)

  status RefundStatus @default(PENDING)

  reason RefundReason? @default(USER_REQUEST)
  notes  String?

  paymentProvider PaymentProvider @default(RAZORPAY) @map("payment_provider")

  providerRefundId String? @unique @map("provider_refund_id")

  metadata Json?

  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([paymentId])
  @@index([status])
}

model WebhookEvent {
  id String @id @default(uuid()) @db.Uuid

  provider   String // stripe, razorpay
  eventType  String @map("event_type") // e.g. invoice.paid, payment.failed
  externalId String @map("external_id") // provider event id

  payload Json

  status WebhookStatus @default(RECEIVED)

  attempts    Int       @default(0)
  nextRetryAt DateTime? @map("next_retry_at")
  processedAt DateTime? @map("processed_at")
  error       String?

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  identityId  String?    @map("identity_id") @db.Uuid
  identity    Identity?  @relation(fields: [identityId], references: [id])
  customerId  String?    @map("customer_id") @db.Uuid
  customer    Customer?  @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([provider, externalId])
  @@index([status, nextRetryAt])
  @@index([workspaceId])
  @@index([identityId])
  @@index([customerId])
}

model OutboxEvent {
  id String @id @default(uuid()) @db.Uuid

  eventType String @map("event_type") // e.g. send_email, webhook_notification
  payload   Json

  status   OutboxStatus @default(PENDING)
  attempts Int          @default(0)

  nextRetryAt DateTime? @map("next_retry_at")
  scheduledAt DateTime? @map("scheduled_at")
  lockedAt    DateTime? @map("locked_at") // for distributed locking when processing

  jobId         String? @map("job_id") // QStash message ID
  processingKey String? @unique @map("processing_key") // for idempotent processing

  processedAt DateTime? @map("processed_at")
  lastError   String?   @map("last_error")

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  identityId  String?    @map("identity_id") @db.Uuid
  identity    Identity?  @relation(fields: [identityId], references: [id])
  customerId  String?    @map("customer_id") @db.Uuid
  customer    Customer?  @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, nextRetryAt])
  @@index([status, scheduledAt])
  @@index([status, lockedAt])
  @@index([scheduledAt])
  @@index([lockedAt])
}

model Media {
  id String @id @default(uuid()) @db.Uuid

  fileName String @map("file_name")
  mimeType String @map("mime_type")
  size     Int

  storageKey String  @map("storage_key") // B2 key
  url        String
  cdnUrl     String? @map("cdn_url")

  status MediaStatus @default(UPLOADING)

  checksum String? // integrity check
  metadata Json?

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  identityId  String?    @map("identity_id") @db.Uuid
  identity    Identity?  @relation(fields: [identityId], references: [id])
  customerId  String?    @map("customer_id") @db.Uuid
  customer    Customer?  @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fileAttachments FileAttachment[]
  mediaJobs       MediaJob[]

  @@unique([storageKey])
  @@index([workspaceId])
  @@index([identityId])
  @@index([customerId])
  @@index([status])
}

model FileAttachment {
  id String @id @default(uuid()) @db.Uuid

  mediaId String @map("media_id") @db.Uuid
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  entityType String @map("entity_type") // SUPPORT_TICKET, MESSAGE, etc.
  entityId   String @map("entity_id")

  workspaceId String?    @map("workspace_id") @db.Uuid
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  identityId  String?    @map("identity_id") @db.Uuid
  identity    Identity?  @relation(fields: [identityId], references: [id])
  customerId  String?    @map("customer_id") @db.Uuid
  customer    Customer?  @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([mediaId])
  @@index([workspaceId])
}

model MediaJob {
  id String @id @default(uuid()) @db.Uuid

  mediaId String @map("media_id") @db.Uuid
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  jobType String @map("job_type") // THUMBNAIL, SCAN, etc.

  status MediaJobStatus @default(PENDING)
  error  String?

  createdAt   DateTime  @default(now()) @map("created_at")
  processedAt DateTime? @map("processed_at")

  @@index([mediaId])
  @@index([status])
}
